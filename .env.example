# Copy this file to .env and fill in real values. .env is git-ignored.

# Network
HOST=0.0.0.0
PORT=5000

# Live mode: where dump1090 publishes its aircraft feed
DUMP1090_URL=http://127.0.0.1:8080/data/aircraft.json

# Optional: enables the "FROM / TO / airline" enrichment panel.
# Get a free key at https://aviationstack.com/ — leave blank to disable.
# This key is read server-side only (app/server.py) and is NEVER sent to the browser.
AVIATIONSTACK_API_KEY=

# CORS — "*" is fine for a closed LAN kiosk
ALLOWED_ORIGINS=*

DEBUG=false
MAP_CENTER_LAT=29.37
MAP_CENTER_LON=47.98
MAP_ZOOM=7
