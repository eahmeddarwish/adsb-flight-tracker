# Sample Raspberry Pi Wi-Fi config.
# Copy to /etc/wpa_supplicant/wpa_supplicant.conf on the Pi itself,
# fill in your real network name/password there, and NEVER commit
# the filled-in version to git (it is already in .gitignore).

country=KW
ctrl_interface=DIR=/var/run/wpa_supplicant GROUP=netdev
update_config=1
network={
    ssid="YOUR_WIFI_NAME"
    psk="YOUR_WIFI_PASSWORD"
    key_mgmt=WPA-PSK
}
